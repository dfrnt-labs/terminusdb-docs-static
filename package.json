{
  "name": "terminusdb-docs-static",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sitemap": "next-sitemap",
    "dev": "next dev",
    "build": "next build",
    "cmsdev": "next dev",
    "cmsbuild": "next build",
    "postbuild": "npm run sitemap",
    "start": "next start",
    "lint": "next lint",
    "test:examples": "npx mocha scripts/docs-example-tests/run-colocated-examples.test.mjs scripts/docs-example-tests/run-http-examples.test.mjs --timeout 30000",
    "test:examples:legacy": "node scripts/docs-example-tests/extract-examples.mjs && npx mocha scripts/docs-example-tests/run-examples.test.mjs --timeout 30000",
    "examples:migrate": "node scripts/docs-example-tests/extract-examples.mjs && node scripts/docs-example-tests/migrate-annotations.mjs",
    "test:nav": "node scripts/docs-example-tests/nav-integrity.mjs",
    "test:render": "npm run test:nav && node scripts/docs-example-tests/render-check.mjs",
    "test:branding": "node scripts/docs-example-tests/branding-lint.mjs",
    "test:stubs": "node scripts/docs-example-tests/stub-detector.mjs",
    "test:inline-annotations": "node scripts/docs-example-tests/inline-annotations-lint.mjs",
    "test:links": "node scripts/docs-example-tests/link-checker.mjs",
    "test:headings": "node scripts/docs-example-tests/heading-lint.mjs",
    "test:http-examples": "npx mocha scripts/docs-example-tests/run-http-examples.test.mjs --timeout 30000",
    "test:all": "npm run test:headings && npm run test:nav && npm run test:inline-annotations && npm run test:links && npm run test:branding && npm run test:stubs && npm run test:http-examples"
  },
  "browser": {
    "tls": false,
    "net": false,
    "fs": false,
    "child_process": false,
    "perf_hooks": false
  },
  "dependencies": {
    "@algolia/autocomplete-core": "^1.9.2",
    "@headlessui/react": "^2.1.0",
    "@markdoc/markdoc": "^0.4.0",
    "@markdoc/next.js": "^0.3.4",
    "@sindresorhus/slugify": "^2.1.0",
    "@tailwindcss/postcss": "^4.1.2",
    "@tailwindcss/typography": "^0.5.7",
    "@types/node": "^20.10.8",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/react-highlight-words": "^0.16.4",
    "@types/swagger-ui-react": "^5.18.0",
    "axios": "^1.8.4",
    "caniuse-lite": "^1.0.30001747",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.0.2",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "fast-glob": "^3.2.12",
    "flexsearch": "^0.7.31",
    "flowbite": "^1.6.5",
    "fs-extra": "^11.3.0",
    "js-yaml": "^4.1.0",
    "lightningcss": "^1.32.0",
    "lucide-react": "^0.561.0",
    "motion": "^12.23.26",
    "next": "^14.0.4",
    "next-themes": "^0.2.1",
    "prism-react-renderer": "^2.0.6",
    "prismjs": "^1.29.0",
    "probe-image-size": "^7.2.3",
    "puppeteer": "^24.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-highlight-words": "^0.20.0",
    "showdown": "^2.1.0",
    "simple-functional-loader": "^1.2.1",
    "swagger-ui-react": "^5.20.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.2",
    "tailwindcss-animate": "^1.0.7",
    "terminusdb": "^12.0.5",
    "turndown": "^7.2.0",
    "typescript": "^5.3.3",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/mermaid": "^9.2.0",
    "@types/prismjs": "^1.26.0",
    "autoprefixer": "^10.4.14",
    "dotenv": "^16.1.4",
    "next-sitemap": "^4.1.3",
    "postcss": "^8.4.24",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sharp": "0.33.1"
  }
}
